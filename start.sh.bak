#!/bin/bash
echo ""
echo "  त  Starting Tatva AI..."
echo ""

cd ~/Desktop/tatva/backend

# Start ChromaDB server
echo "🔷 Starting ChromaDB..."
chroma run --path ./chroma_db --port 8000 &
CHROMA_PID=$!
sleep 4

# Verify ChromaDB
if curl -s http://localhost:8000/api/v2/heartbeat > /dev/null; then
  echo "✅ ChromaDB running on port 8000"
else
  echo "⚠️  ChromaDB may still be starting..."
fi

# Start Backend
echo "🔷 Starting Backend..."
export PATH="/usr/local/bin:/opt/homebrew/bin:$PATH"
node server.js &
BACKEND_PID=$!
sleep 2

# Start Frontend
echo "🔷 Starting Frontend..."
cd ~/Desktop/tatva/frontend
npm run dev &
FRONTEND_PID=$!

echo ""
echo "✅ ChromaDB  → http://localhost:8000"
echo "✅ Backend   → http://localhost:5001"
echo "✅ Frontend  → http://localhost:5173"
echo ""
echo "Open http://localhost:5173"
echo "Press Ctrl+C to stop everything"
echo ""

trap "kill $CHROMA_PID $BACKEND_PID $FRONTEND_PID 2>/dev/null" EXIT INT TERM
wait
